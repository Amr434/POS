<!DOCTYPE html>
<html lang="ar"  dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POS</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />

    <!-- ✅ Bootstrap Icons -->
    <link href="~/lib/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />

    <!-- ✅ Tajawal Font (via CSS file) -->
    <link href="~/fonts/tajawal/tajawal.css" rel="stylesheet" />

    <!-- ✅ Site CSS -->
    <link href="~/css/site.css" asp-append-version="true" rel="stylesheet" />
    <link href="~/POS.styles.css" asp-append-version="true" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <!-- Google Fonts - Arabic -->
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <!-- Logo Section -->
        <div class="sidebar-header">
            <div class="logo-wrapper">
                <div class="logo-icon">م</div>
                <span class="logo-text">نظام الإدارة</span>
            </div>
            <button class="toggle-btn" id="toggleSidebar">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <!-- الرئيسية -->
            <div class="nav-item">
                <a asp-controller="Home" asp-action="Index" class="nav-link" data-title="الرئيسية" data-page="الرئيسية">
                    <i class="bi bi-house-door"></i>
                    <span>الرئيسية</span>
                </a>
            </div>
            <!-- المنتجات -->
            <div class="nav-item has-submenu">
                <a class="nav-link active" data-title="المنتجات" data-page="المنتجات">
                    <i class="bi bi-box-seam"></i>
                    <span>المنتجات</span>

                </a>
                <div class="submenu">
                    <a asp-controller="Products" asp-action="Index" class="nav-link" data-title="عرض المنتجات">
                        <span>عرض المنتجات</span>
                    </a>
                    <a asp-controller="Categories"
                       asp-action="Index" class="nav-link" data-title="الفئات">
                        <span>الفئات</span>
                    </a>
                    <a asp-controller="Products" asp-action="Create" class="nav-link" data-title=" إضافة منتج">
                        <span>إضافة منتج </span>
                    </a>
                </div>
            </div>

            <!-- المبيعات -->
            <div class="nav-item has-submenu">
                <a href="#" class="nav-link" data-title="المبيعات" data-page="المبيعات">
                    <i class="bi bi-cart3"></i>
                    <span>المبيعات</span>
                </a>
                <div class="submenu">
                    <a href="#" class="nav-link" data-title="فاتورة جديدة">
                        <span>فاتورة جديدة</span>
                    </a>
                    <a href="#" class="nav-link" data-title="سجل المبيعات">
                        <span>سجل المبيعات</span>
                    </a>
                </div>
            </div>

            <!-- المبيعات -->
            <div class="nav-item has-submenu">
                <a href="#" class="nav-link" data-title="المبيعات" data-page="المبيعات">
                    <i class="bi bi-cart3"></i>
                    <span>المشتريات</span>
                </a>
                <div class="submenu">
                    <a asp-controller="Purchases" asp-action="Create" class="nav-link" data-title="المشتريات">
                        <span>فاتورة جديدة</span>
                    </a>
                    <a asp-controller="Purchases" asp-action="Index" class="nav-link" data-title="سجل المشتريات">
                        <span>سجل المشتريات</span>
                    </a>
                </div>
            </div>

            <!-- المخزون -->
            <div class="nav-item">
                <a href="#" class="nav-link" data-title="المخزون" data-page="المخزون">
                    <i class="bi bi-archive"></i>
                    <span>المخزون</span>
                    <span class="nav-badge">12</span>
                </a>
            </div>

            <!-- الفواتير -->
            <div class="nav-item">
                <a href="#" class="nav-link" data-title="الفواتير" data-page="الفواتير">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>الفواتير</span>
                </a>
            </div>

            <!-- الأقساط -->
            <div class="nav-item">
                <a href="#" class="nav-link" data-title="الأقساط" data-page="الأقساط">
                    <i class="bi bi-credit-card"></i>
                    <span>الأقساط</span>
                    <span class="nav-badge">3</span>
                </a>
            </div>

            <!-- التنبيهات -->
            <div class="nav-item">
                <a href="#" class="nav-link" data-title="التنبيهات" data-page="التنبيهات">
                    <i class="bi bi-bell"></i>
                    <span>التنبيهات</span>
                    <span class="nav-badge">5</span>
                </a>
            </div>

            <!-- التقارير -->
            <div class="nav-item has-submenu">
                <a href="#" class="nav-link" data-title="التقارير" data-page="التقارير">
                    <i class="bi bi-graph-up"></i>
                    <span>التقارير</span>
                </a>
                <div class="submenu">
                    <a href="#" class="nav-link" data-title="تقرير المبيعات">
                        <span>تقرير المبيعات</span>
                    </a>
                    <a href="#" class="nav-link" data-title="تقرير المخزون">
                        <span>تقرير المخزون</span>
                    </a>
                    <a href="#" class="nav-link" data-title="تقرير الأرباح">
                        <span>تقرير الأرباح</span>
                    </a>
                </div>
            </div>
        </nav>

        <!-- User Section -->
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">أ</div>
                <div class="user-info">
                    <div class="user-name">أحمد محمد</div>
                    <div class="user-role">مدير النظام</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div class="d-flex align-items-center gap-3">
                <button class="mobile-menu-btn" id="mobileMenuBtn">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <h1 class="page-title" id="pageTitle">المنتجات</h1>
            </div>
            <div class="header-actions">
                <div class="search-box">
                    <input type="text" class="search-input" placeholder="بحث...">
                    <i class="bi bi-search search-icon"></i>
                </div>
                <button class="header-btn">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="notification-dot"></span>
                </button>
                <button class="header-btn">
                    <i class="bi bi-gear fs-5"></i>
                </button>
            </div>
        </header>

        <!-- Content Area -->
        <div class="content-area">
            <div class="content-card">
               @*  <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-layout-text-sidebar-reverse"></i>
                    </div>
                    <h2 class="empty-title" id="contentTitle">صفحة المنتجات</h2>
                    <p class="empty-text">محتوى الصفحة سيظهر هنا</p>
                </div> *@
                @RenderBody()

            </div>
        </div>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
