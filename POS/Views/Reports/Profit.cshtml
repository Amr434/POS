@model POS.Models.Reports.ProfitReportVm
@{
    ViewData["Title"] = "تقرير الأرباح";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1" style="color: var(--text-primary); font-size: 20px; font-weight: 700;">
            <i class="bi bi-graph-up-arrow ms-2"></i>
            تقرير الأرباح
        </h2>
        <div style="color: var(--text-muted); font-size: 13px;">
            الفترة: @Model.From.ToString("yyyy-MM-dd") إلى @Model.To.ToString("yyyy-MM-dd")
        </div>
        <div style="color: var(--text-muted); font-size: 12px;" class="mt-1">
            ملاحظة: تكلفة البضاعة **تقديرية** (متوسط مرجّح من دفعات الشراء حتى تاريخ النهاية).
        </div>
    </div>
    <div class="no-print d-flex gap-2">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">كل التقارير</a>
        <a asp-action="ProfitCsv"
           asp-route-from="@Model.From.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.To.ToString("yyyy-MM-dd")"
           asp-route-groupBy="@Model.GroupBy"
           class="btn btn-sm btn-outline-primary">
            تصدير CSV
        </a>
    </div>
</div>

@await Html.PartialAsync("_ReportFilters", new POS.Models.Reports.ReportFiltersVm { From = Model.From, To = Model.To, GroupBy = Model.GroupBy })

<div class="row g-3 mt-1">
    <div class="col-lg-3 col-md-6">
        <div class="content-card">
            <div style="color: var(--text-muted); font-size: 12px;">الإيراد</div>
            <div style="color: var(--text-primary); font-weight: 800; font-size: 22px;">@Model.Revenue</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="content-card">
            <div style="color: var(--text-muted); font-size: 12px;">تكلفة تقديرية</div>
            <div style="color: var(--text-primary); font-weight: 800; font-size: 22px;">@Model.EstimatedCogs</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="content-card">
            <div style="color: var(--text-muted); font-size: 12px;">المصروفات</div>
            <div style="color: var(--text-primary); font-weight: 800; font-size: 22px;">@Model.Expenses</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="content-card">
            <div style="color: var(--text-muted); font-size: 12px;">الربح</div>
            <div style="color: var(--text-primary); font-weight: 900; font-size: 22px;">@Model.Profit</div>
        </div>
    </div>
</div>

<div class="content-card mt-3">
    <h3 class="mb-2" style="color: var(--text-primary); font-size: 16px; font-weight: 700;">
        ملخص حسب @(Model.GroupBy == "month" ? "الشهر" : "اليوم")
    </h3>

    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>الفترة</th>
                    <th class="text-nowrap">الإيراد</th>
                    <th class="text-nowrap">تكلفة تقديرية</th>
                    <th class="text-nowrap">المصروفات</th>
                    <th class="text-nowrap">الربح</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Groups.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">لا توجد بيانات</td></tr>
                }
                else
                {
                    foreach (var g in Model.Groups)
                    {
                        <tr>
                            <td>@(Model.GroupBy == "month" ? g.Period.ToString("yyyy-MM") : g.Period.ToString("yyyy-MM-dd"))</td>
                            <td>@g.Revenue</td>
                            <td>@g.EstimatedCogs</td>
                            <td>@g.Expenses</td>
                            <td>@g.Profit</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

