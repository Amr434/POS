@model POS.Models.Reports.ReportsDashboardVm
@{
    ViewData["Title"] = "التقارير";
}

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <div>
        <h2 class="mb-1" style="color: var(--text-primary); font-size: 20px; font-weight: 700;">
            <i class="bi bi-graph-up ms-2"></i>
            التقارير
        </h2>
        <div style="color: var(--text-muted); font-size: 13px;">اختر نوع التقرير ثم حدد الفترة والتجميع</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Sales" class="btn btn-sm btn-primary">تقرير المبيعات</a>
        <a asp-action="Inventory" class="btn btn-sm btn-outline-primary">تقرير المخزون</a>
        <a asp-action="Profit" class="btn btn-sm btn-outline-primary">تقرير الأرباح</a>
        <a asp-action="Expenses" class="btn btn-sm btn-outline-primary">تقرير المصروفات</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-3 col-md-6">
        <a asp-action="Sales" class="text-decoration-none">
            <div class="content-card" style="cursor:pointer;">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary"><i class="bi bi-cash-stack"></i></div>
                    <div>
                        <div style="color: var(--text-primary); font-weight: 700;">تقرير المبيعات</div>
                        <div style="color: var(--text-muted); font-size: 12px;">إجماليات + تجميع يومي/شهري</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a asp-action="Inventory" class="text-decoration-none">
            <div class="content-card" style="cursor:pointer;">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning"><i class="bi bi-box-seam"></i></div>
                    <div>
                        <div style="color: var(--text-primary); font-weight: 700;">تقرير المخزون</div>
                        <div style="color: var(--text-muted); font-size: 12px;">الرصيد الحالي + مشتريات الفترة</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a asp-action="Profit" class="text-decoration-none">
            <div class="content-card" style="cursor:pointer;">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div style="color: var(--text-primary); font-weight: 700;">تقرير الأرباح</div>
                        <div style="color: var(--text-muted); font-size: 12px;">مبيعات - تكلفة تقديرية - مصروفات</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a asp-action="Expenses" class="text-decoration-none">
            <div class="content-card" style="cursor:pointer;">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon bg-danger"><i class="bi bi-receipt"></i></div>
                    <div>
                        <div style="color: var(--text-primary); font-weight: 700;">تقرير المصروفات</div>
                        <div style="color: var(--text-muted); font-size: 12px;">تفاصيل + تجميع يومي/شهري</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .no-print { display: none !important; }
            .content-card { border: none !important; box-shadow: none !important; }
        }
    </style>
}

