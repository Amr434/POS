@{
    ViewData["Title"] = "الرئيسية";
}
@model POS.Models.HomeDashboardVm

<!-- Page Header -->
<div class="page-header-section">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title-main">
                <i class="bi bi-speedometer2 ms-3"></i>
                لوحة التحكم
            </h1>
            <p class="page-subtitle">مرحباً بك في نظام إدارة نقاط البيع</p>
        </div>
        <div>
            <span class="text-secondary">اليوم: @Model.Today.ToString("dd/MM/yyyy")</span>
        </div>
    </div>
</div>

<!-- Stats Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="stat-info">
                <div class="stat-value">@Model.TodaySalesTotal.ToString("N0") ر.س</div>
                <div class="stat-label">مبيعات اليوم</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="stat-info">
                <div class="stat-value">@Model.TotalProducts.ToString("N0")</div>
                <div class="stat-label">إجمالي المنتجات</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="stat-info">
                <div class="stat-value">@Model.LowStockCount.ToString("N0")</div>
                <div class="stat-label">تنبيهات المخزون</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-danger">
                <i class="bi bi-receipt"></i>
            </div>
            <div class="stat-info">
                <div class="stat-value">@Model.TodayInvoicesCount.ToString("N0")</div>
                <div class="stat-label">فواتير اليوم</div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="content-card">
            <h3 class="mb-3" style="color: var(--text-primary); font-size: 18px; font-weight: 600;">
                <i class="bi bi-lightning-charge ms-2"></i>
                إجراءات سريعة
            </h3>
            <div class="row g-3">
                <div class="col-lg-3 col-md-6">
                    <a href="#" class="quick-action-card">
                        <div class="quick-action-icon" style="background: linear-gradient(135deg, #10b981, #14b8a6);">
                            <i class="bi bi-cart-plus"></i>
                        </div>
                        <span>فاتورة جديدة</span>
                    </a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Products" asp-action="Create" class="quick-action-card">
                        <div class="quick-action-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                            <i class="bi bi-plus-circle"></i>
                        </div>
                        <span>إضافة منتج</span>
                    </a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Reports" asp-action="Index" class="quick-action-card">
                        <div class="quick-action-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <span>التقارير</span>
                    </a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <a asp-controller="Categories" asp-action="Index" class="quick-action-card">
                        <div class="quick-action-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                            <i class="bi bi-tags"></i>
                        </div>
                        <span>الفئات</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity & Low Stock -->
<div class="row g-3">
    <!-- Recent Sales -->
    <div class="col-lg-8">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 style="color: var(--text-primary); font-size: 18px; font-weight: 600;">
                    <i class="bi bi-clock-history ms-2"></i>
                    آخر المبيعات
                </h3>
                <a href="#" class="text-decoration-none" style="color: var(--primary-color); font-size: 14px;">
                    عرض الكل <i class="bi bi-arrow-left"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table dashboard-table">
                    <thead>
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>التاريخ</th>
                            <th>العميل</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentSales == null || Model.RecentSales.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-secondary py-4">لا توجد مبيعات حتى الآن</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var s in Model.RecentSales)
                            {
                                var isCompleted = s.RemainingAmount <= 0;
                                <tr>
                                    <td>#INV-@s.SaleId.ToString("D4")</td>
                                    <td>@s.SaleDate.ToString("HH:mm")</td>
                                    <td>@s.CustomerName</td>
                                    <td>@s.TotalAmount.ToString("N0") ر.س</td>
                                    <td>
                                        @if (isCompleted)
                                        {
                                            <span class="badge-new">مكتمل</span>
                                        }
                                        else
                                        {
                                            <span class="badge-reserved">معلق</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Low Stock Alert -->
    <div class="col-lg-4">
        <div class="content-card">
            <h3 class="mb-3" style="color: var(--text-primary); font-size: 18px; font-weight: 600;">
                <i class="bi bi-exclamation-triangle-fill ms-2" style="color: #f59e0b;"></i>
                تنبيهات المخزون
            </h3>
            <div class="d-flex flex-column gap-3">
                @if (Model.LowStockItems == null || Model.LowStockItems.Count == 0)
                {
                    <div class="text-secondary text-center py-3">لا توجد تنبيهات مخزون</div>
                }
                else
                {
                    foreach (var p in Model.LowStockItems)
                    {
                        var isOut = p.RemainingQuantity <= 0;
                        <div class="alert-item">
                            <div class="d-flex align-items-center gap-3">
                                <div class="alert-icon">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div style="color: var(--text-primary); font-weight: 500; font-size: 14px;">@p.ProductName</div>
                                    <div style="color: var(--text-muted); font-size: 12px;">الكمية: @p.RemainingQuantity فقط</div>
                                </div>
                                @if (isOut)
                                {
                                    <span class="badge-sold">نفذ</span>
                                }
                                else
                                {
                                    <span class="badge-low">منخفض</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<style>
    .quick-action-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 24px;
        background-color: var(--card-bg);
        border: 1px solid var(--sidebar-border);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .quick-action-card:hover {
        transform: translateY(-4px);
        border-color: rgba(16, 185, 129, 0.4);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    }

    .quick-action-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }

    .quick-action-card span {
        color: var(--text-primary);
        font-weight: 500;
        font-size: 14px;
    }

    .dashboard-table {
        margin: 0;
    }

    .dashboard-table thead th {
        background-color: var(--body-bg);
        color: var(--text-secondary);
        font-size: 13px;
        font-weight: 600;
        border: none;
        padding: 12px;
    }

    .dashboard-table tbody td {
        color: var(--text-primary);
        font-size: 14px;
        border-color: var(--sidebar-border);
        padding: 12px;
    }

    .alert-item {
        padding: 12px;
        background-color: var(--body-bg);
        border: 1px solid var(--sidebar-border);
        border-radius: 8px;
    }

    .alert-icon {
        width: 40px;
        height: 40px;
        background-color: rgba(245, 158, 11, 0.15);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f59e0b;
        font-size: 18px;
    }
</style>