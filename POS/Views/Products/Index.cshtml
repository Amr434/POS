@model POS.Models.PaginatedList<Product>
@using Domain.Entities
@{
    ViewData["Title"] = "إدارة المنتجات";
    var categories = ViewBag.Categories as IEnumerable<Category>;
}

<link rel="stylesheet" href="~/css/Products/index.css" />

<div class="products-page">
    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" id="successAlert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error" id="errorAlert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <!-- Search and Filters -->
    <div class="search-filter-section">
        <div class="section-header">
            <h2 class="section-title">
                <i class="bi bi-funnel"></i>
                البحث عن منتج
            </h2>
        </div>

        <div class="filters-row">
            <div class="filter-group">
                <label class="filter-label">اسم المنتج أو الباركود...</label>
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="search-input" id="searchInput" 
                           placeholder="ابحث بالاسم أو الباركود..." 
                           value="@ViewBag.CurrentSearch">
                </div>
            </div>

            <div class="filter-group">
                <label class="filter-label">التصنيف</label>
                <select class="filter-select" id="categoryFilter">
                    <option value="">جميع التصنيفات</option>
                    @if (categories != null)
                    {
                        foreach (var category in categories)
                        {
                            <option value="@category.Id" selected="@(ViewBag.CurrentCategory == category.Id ? "selected" : null)">
                                @category.Name
                            </option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="products-table-card">
        <div class="table-header">
            <h3 class="table-title">
                قائمة المنتجات (<span id="totalCount">@Model.TotalCount</span> منتج)
            </h3>
            <a asp-action="Create" class="btn-add">
                <i class="bi bi-plus-circle"></i>
                إضافة منتج جديد
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="table-container">
                <table class="products-table">
                    <thead>
                        <tr>
                            <th>الصورة</th>
                            <th>المنتج</th>
                            <th>الفئة</th>
                            <th>سعر البيع</th>
                            <th>الكمية</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="productsTableBody">
                        @foreach (var product in Model)
                        {
                            var statusClass = product.Status.ToString().ToLower() == "new" ? "new" : (product.Status.ToString().ToLower() == "reserved" ? "reserved" : "sold");
                            var statusText = product.Status.ToString() == "New" ? "جديد" : (product.Status.ToString() == "Reserved" ? "محجوز" : "مُباع");

                            <tr data-name="@product.Name"
                                data-barcode="@product.Barcode"
                                data-category="@product.CategoryId">
                                <td>
                                    <div class="product-image">
                                        @if (!string.IsNullOrEmpty(product.ImagePath))
                                        {
                                            <img src="@product.ImagePath" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                                        }
                                        else
                                        {
                                            <i class="bi bi-box-seam"></i>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="product-cell">
                                        <div class="product-info">
                                            <span class="product-name">@product.Name</span>
                                            @if (!string.IsNullOrEmpty(product.Barcode))
                                            {
                                                <span class="product-sku">SKU: @product.Barcode</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="category-badge">@(product.Category?.Name ?? "غير مصنف")</span>
                                </td>
                                <td class="price-cell">@product.SalePrice.ToString("N0") ج.م</td>
                                
                                <td>
                                    <span class="status-badge @statusClass">@statusText</span>
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a href="javascript:void(0)" onclick="openPreviewModal(@product.Id)" class="btn-action btn-view" title="عرض">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="javascript:void(0)" onclick="openEditModal(@product.Id)" class="btn-action btn-edit" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button onclick="openDeleteModal(@product.Id, '@product.Name')" class="btn-action btn-delete" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- ✅ PAGINATION CONTROLS -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination-container">
                    <div class="pagination-info">
                        <span>عرض @((Model.PageIndex - 1) * Model.PageSize + 1) - @(((Model.PageIndex - 1) * Model.PageSize) + Model.Count) من أصل @Model.TotalCount منتج</span>
                    </div>
              
                    <div class="pagination-controls">
                        <ul class="pagination">
                            <!-- First Page -->
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="1"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>

                            <!-- Previous Page -->
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                            <!-- Page Numbers -->
                            @{
                                var startPage = Math.Max(1, Model.PageIndex - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                            }

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="1"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="@i"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">@i</a>
                                </li>
                            }

                            @if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="@Model.TotalPages"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">@Model.TotalPages</a>
                                </li>
                            }

                            <!-- Next Page -->
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            <!-- Last Page -->
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@Model.TotalPages"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="page-size-selector">
                        <label for="pageSizeSelect">عدد العناصر:</label>
                        <select id="pageSizeSelect" class="page-size-select" onchange="changePageSize(this.value)">
                           @foreach (var size in new[] { 10, 20, 50, 100 })
                           {
                                <option value="@size">@size</option>
                           }
                        </select>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h3>لا توجد منتجات</h3>
                <p>قم بإضافة منتج جديد للبدء</p>
                <a asp-action="Create" class="btn-add">
                    <i class="bi bi-plus-circle"></i>
                    إضافة منتج
                </a>
            </div>
        }
    </div>
</div>
@section Scripts {
    <script src="~/js/Products/index.js"></script>
}

