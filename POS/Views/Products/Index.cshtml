@model POS.Models.PaginatedList<Product>
@using Domain.Entities
@{
    ViewData["Title"] = "إدارة المنتجات";
    var categories = ViewBag.Categories as IEnumerable<Category>;
}

<link rel="stylesheet" href="~/css/Products/index.css" />

<div class="products-page">
    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" id="successAlert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error" id="errorAlert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <!-- Search and Filters -->
    <div class="search-filter-section">
        <div class="section-header">
            <h2 class="section-title">
                <i class="bi bi-funnel"></i>
                البحث عن منتج
            </h2>
        </div>

        <div class="filters-row">
            <div class="filter-group">
                <label class="filter-label">اسم المنتج أو الباركود...</label>
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="search-input" id="searchInput" 
                           placeholder="ابحث بالاسم أو الباركود..." 
                           value="@ViewBag.CurrentSearch">
                </div>
            </div>

            <div class="filter-group">
                <label class="filter-label">التصنيف</label>
                <select class="filter-select" id="categoryFilter">
                    <option value="">جميع التصنيفات</option>
                    @if (categories != null)
                    {
                        foreach (var category in categories)
                        {
                            <option value="@category.Id" selected="@(ViewBag.CurrentCategory == category.Id ? "selected" : null)">
                                @category.Name
                            </option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="products-table-card">
        <div class="table-header">
            <h3 class="table-title">
                قائمة المنتجات (<span id="totalCount">@Model.TotalCount</span> منتج)
            </h3>
            <a asp-action="Create" class="btn-add">
                <i class="bi bi-plus-circle"></i>
                إضافة منتج جديد
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="table-container">
                <table class="products-table">
                    <thead>
                        <tr>
                            <th>الصورة</th>
                            <th>المنتج</th>
                            <th>الفئة</th>
                            <th>سعر البيع</th>
                            <th>الكمية</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="productsTableBody">
                        @foreach (var product in Model)
                        {
                            var statusClass = product.Status.ToString().ToLower() == "new" ? "new" : (product.Status.ToString().ToLower() == "reserved" ? "reserved" : "sold");
                            var statusText = product.Status.ToString() == "New" ? "جديد" : (product.Status.ToString() == "Reserved" ? "محجوز" : "مُباع");

                            <tr data-name="@product.Name"
                                data-barcode="@product.Barcode"
                                data-category="@product.CategoryId">
                                <td>
                                    <div class="product-image">
                                        @if (!string.IsNullOrEmpty(product.ImagePath))
                                        {
                                            <img src="@product.ImagePath" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                                        }
                                        else
                                        {
                                            <i class="bi bi-box-seam"></i>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="product-cell">
                                        <div class="product-info">
                                            <span class="product-name">@product.Name</span>
                                            @if (!string.IsNullOrEmpty(product.Barcode))
                                            {
                                                <span class="product-sku">SKU: @product.Barcode</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="category-badge">@(product.Category?.Name ?? "غير مصنف")</span>
                                </td>
                                <td class="price-cell">@product.SalePrice.ToString("N0") ج.م</td>
                                
                                <td>
                                    <span class="status-badge @statusClass">@statusText</span>
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a href="javascript:void(0)" onclick="openPreviewModal(@product.Id)" class="btn-action btn-view" title="عرض">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="javascript:void(0)" onclick="openEditModal(@product.Id)" class="btn-action btn-edit" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button onclick="openDeleteModal(@product.Id, '@product.Name')" class="btn-action btn-delete" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- ✅ PAGINATION CONTROLS -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination-container">
                    <div class="pagination-info">
                        <span>عرض @((Model.PageIndex - 1) * Model.PageSize + 1) - @(((Model.PageIndex - 1) * Model.PageSize) + Model.Count) من أصل @Model.TotalCount منتج</span>
                    </div>
              
                    <div class="pagination-controls">
                        <ul class="pagination">
                            <!-- First Page -->
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="1"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>

                            <!-- Previous Page -->
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                            <!-- Page Numbers -->
                            @{
                                var startPage = Math.Max(1, Model.PageIndex - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                            }

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="1"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="@i"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">@i</a>
                                </li>
                            }

                            @if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-pageNumber="@Model.TotalPages"
                                       asp-route-searchTerm="@ViewBag.CurrentSearch"
                                       asp-route-categoryId="@ViewBag.CurrentCategory">@Model.TotalPages</a>
                                </li>
                            }

                            <!-- Next Page -->
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            <!-- Last Page -->
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@Model.TotalPages"
                                   asp-route-searchTerm="@ViewBag.CurrentSearch"
                                   asp-route-categoryId="@ViewBag.CurrentCategory">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="page-size-selector">
                        <label for="pageSizeSelect">عدد العناصر:</label>
                        <select id="pageSizeSelect" class="page-size-select" onchange="changePageSize(this.value)">
                           @foreach (var size in new[] { 10, 20, 50, 100 })
                           {
                                <option value="@size">@size</option>
                           }
                        </select>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h3>لا توجد منتجات</h3>
                <p>قم بإضافة منتج جديد للبدء</p>
                <a asp-action="Create" class="btn-add">
                    <i class="bi bi-plus-circle"></i>
                    إضافة منتج
                </a>
            </div>
        }
    </div>
</div>

<!-- Preview Modal -->
<div id="previewModal" class="modal">
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h3>تفاصيل المنتج</h3>
            <button type="button" class="close-btn" onclick="closePreviewModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="modal-body">
            <div class="preview-container">
                <div id="previewImageContainer" class="preview-image-section">
                    <img id="previewImage" alt="Product Image" />
                </div>
                <div class="preview-details">
                    <div class="detail-row">
                        <label>اسم المنتج:</label>
                        <span id="previewName"></span>
                    </div>
                    <div class="detail-row">
                        <label>الفئة:</label>
                        <span id="previewCategory"></span>
                    </div>
                    <div class="detail-row">
                        <label>سعر البيع:</label>
                        <span id="previewSalePrice"></span>
                    </div>
                    <div class="detail-row">
                        <label>الباركود:</label>
                        <span id="previewBarcode"></span>
                    </div>
                    <div class="detail-row">
                        <label>الحالة:</label>
                        <span id="previewStatus"></span>
                    </div>
                    <div id="previewEngineContainer" class="detail-row" style="display: none;">
                        <label>رقم المحرك:</label>
                        <span id="previewEngine"></span>
                    </div>
                    <div id="previewChassisContainer" class="detail-row" style="display: none;">
                        <label>رقم الشاسيه:</label>
                        <span id="previewChassis"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="modal">
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h3>تعديل المنتج</h3>
            <button type="button" class="close-btn" onclick="closeEditModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="modal-body">
            <form id="editProductForm" enctype="multipart/form-data">
                <input type="hidden" id="editProductId" name="id" />
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="editName">اسم المنتج</label>
                        <input type="text" id="editName" name="name" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label for="editCategoryId">الفئة</label>
                        <select id="editCategoryId" name="categoryId" class="form-control">
                            <option value="">اختر الفئة</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="editSalePrice">سعر البيع</label>
                        <input type="number" id="editSalePrice" name="salePrice" class="form-control" step="0.01" />
                    </div>
                    
                    <div class="form-group">
                        <label for="editMinStock">الحد الأدنى</label>
                        <input type="number" id="editMinStock" name="minStock" class="form-control" value="5" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="editBarcode">الباركود</label>
                        <input type="text" id="editBarcode" name="barcode" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label for="editStatus">الحالة</label>
                        <select id="editStatus" name="status" class="form-control">
                            <option value="0">جديد</option>
                            <option value="1">محجوز</option>
                            <option value="2">مُباع</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="editImageFile">صورة المنتج</label>
                    <div class="image-upload-container">
                        <div class="current-image-preview">
                            <img id="editCurrentImage" style="display: none; max-width: 200px; max-height: 200px; border-radius: 8px;" />
                            <div id="editNoImage" style="display: flex; align-items: center; justify-content: center; width: 200px; height: 200px; background: #f0f0f0; border-radius: 8px;">
                                <i class="bi bi-image" style="font-size: 48px; color: #ccc;"></i>
                            </div>
                        </div>
                        <input type="file" id="editImageFile" name="image" class="form-control" accept="image/*" onchange="previewEditImage(event)" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="editIsMotorcycle" onchange="toggleMotorcycleFieldsEdit()" />
                        <span>منتج دراجة نارية</span>
                    </label>
                </div>

                <div id="editMotorcycleFields" style="display: none;">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="editEngineNumber">رقم المحرك</label>
                            <input type="text" id="editEngineNumber" name="engineNumber" class="form-control" />
                        </div>
                        
                        <div class="form-group">
                            <label for="editChassisNumber">رقم الشاسيه</label>
                            <input type="text" id="editChassisNumber" name="chassisNumber" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="closeEditModal()">إلغاء</button>
                    <button type="submit" class="btn-primary">حفظ التعديلات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal">
    <div class="modal-content modal-sm">
        <div class="modal-header">
            <h3>تأكيد الحذف</h3>
            <button type="button" class="close-btn" onclick="closeDeleteModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="deleteProductId" />
            <div class="delete-confirm-message">
                <i class="bi bi-exclamation-triangle" style="font-size: 48px; color: #dc3545;"></i>
                <p>هل أنت متأكد من حذف المنتج:</p>
                <strong id="deleteProductName"></strong>
                <p class="warning-text">لا يمكن التراجع عن هذا الإجراء</p>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-secondary" onclick="closeDeleteModal()">إلغاء</button>
            <button type="button" class="btn-danger" onclick="confirmDelete()">حذف</button>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/Products/index.js"></script>
}

