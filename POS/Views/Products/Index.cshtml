@model POS.Models.PaginatedList<Domain.Entities.Product>
@using Domain.Entities
@{
    ViewData["Title"] = "إدارة المنتجات";
    var categories = ViewBag.Categories as IEnumerable<Category>;
}

<link rel="stylesheet" href="~/css/Products/index.css" />

<div class="products-page">
    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" id="successAlert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error" id="errorAlert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <!-- Search and Filters -->
    <div class="search-filter-section">
        <div class="section-header">
            <h2 class="section-title">
                <i class="bi bi-funnel"></i>
                البحث عن منتج
            </h2>
        </div>

        <div class="filters-row">
            <div class="filter-group">
                <label class="filter-label">اسم المنتج أو الباركود...</label>
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="search-input" id="searchInput" 
                           placeholder="ابحث بالاسم أو الباركود..." 
                           value="@ViewBag.CurrentSearch">
                </div>
            </div>

            <div class="filter-group">
                <label class="filter-label">التصنيف</label>
                <select class="filter-select" id="categoryFilter">
                    <option value="">جميع التصنيفات</option>
                    @if (categories != null)
                    {
                        foreach (var category in categories)
                        {
                            var selected = ViewBag.CurrentCategory == category.Id ? "selected" : "";
                            <option value="@category.Id" selected="@selected">
                                @category.Name
                            </option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="products-table-card">
        <div class="table-header">
            <h3 class="table-title">
                قائمة المنتجات (<span id="totalCount">@Model.TotalCount</span> منتج)
            </h3>
            <a asp-action="Create" class="btn-add">
                <i class="bi bi-plus-circle"></i>
                إضافة منتج جديد
            </a>
        </div>

        <div class="table-container">
            <table class="products-table">
                <thead>
                    <tr>
                        <th>الصورة</th>
                        <th>المنتج</th>
                        <th>الفئة</th>
                        <th>سعر الشراء</th>
                        <th>سعر البيع</th>
                        <th>الكمية</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="productsTableBody">
                    @foreach (var product in Model)
                    {
                        var stockClass = product.Quantity == 0 ? "out" : (product.Quantity <= product.MinStock ? "low" : "available");
                        var statusClass = product.Status.ToString().ToLower();
                        var statusText = product.Status.ToString() == "New" ? "جديد" : (product.Status.ToString() == "Reserved" ? "محجوز" : "مُباع");

                        <tr data-name="@product.Name"
                            data-barcode="@product.Barcode"
                            data-category="@product.CategoryId"
                            data-stock="@stockClass">
                            <td>
                                <div class="product-image">
                                    @if (!string.IsNullOrEmpty(product.ImagePath))
                                    {
                                        <img src="@product.ImagePath" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                                    }
                                    else
                                    {
                                        <i class="bi bi-box-seam"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="product-cell">
                                    <div class="product-info">
                                        <span class="product-name">@product.Name</span>
                                        @if (!string.IsNullOrEmpty(product.Barcode))
                                        {
                                            <span class="product-sku">SKU: @product.Barcode</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="category-badge">@(product.Category?.Name ?? "غير مصنف")</span>
                            </td>
                            <td class="price-cell">@product.PurchasePrice.ToString("N0") ج.م</td>
                            <td class="price-cell">@product.SalePrice.ToString("N0") ج.م</td>
                            <td>
                             
                                <h6>
                                    @product.Quantity.ToString()

                                </h6>
                            </td>
                            <td>
                                <span class="status-badge @statusClass">@statusText</span>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <a href="javascript:void(0)" onclick="openPreviewModal(@product.Id)" class="btn-action btn-view" title="عرض">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="javascript:void(0)" onclick="openEditModal(@product.Id)" class="btn-action btn-edit" title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button onclick="openDeleteModal(@product.Id, '@product.Name')" class="btn-action btn-delete" title="حذف">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination-container">
                    <div class="pagination-info">
                        عرض <span id="itemsFrom">@((Model.PageIndex - 1) * 10 + 1)</span>
                        إلى <span id="itemsTo">@Math.Min(Model.PageIndex * 10, Model.TotalCount)</span>
                        من <span id="itemsTotal">@Model.TotalCount</span>
                    </div>
    
                    <button class="pagination-btn" id="prevPageBtn" 
                            onclick="goToPage(@(Model.PageIndex - 1))" 
                            @(!Model.HasPreviousPage ? "disabled" : "")>
                        <i class="bi bi-chevron-right"></i>
                        السابق
                    </button>

                    <div class="pagination-numbers" id="paginationNumbers">
                        @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
                        {
                            <button class="pagination-number @(i == Model.PageIndex ? "active" : "")" 
                                    onclick="goToPage(@i)">
                                @i
                            </button>
                        }
                    </div>

                    <button class="pagination-btn" id="nextPageBtn" 
                            onclick="goToPage(@(Model.PageIndex + 1))" 
                            @(!Model.HasNextPage ? "disabled" : "")>
                        التالي
                        <i class="bi bi-chevron-left"></i>
                    </button>

                    <button class="pagination-btn" id="lastPageBtn" 
                            onclick="goToPage(@Model.TotalPages)" 
                            @(!Model.HasNextPage ? "disabled" : "")>
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                </div>

                <div class="pagination-page-size">
                    <label>عرض:</label>
                    <select id="pageSizeSelect" onchange="changePageSize(this.value)">
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>تأكيد الحذف</h2>
        </div>
        <div class="modal-body">
            <p>
                هل أنت متأكد من حذف هذا المنتج؟<br>
                <strong id="deleteProductName"></strong>
            </p>
            <input type="hidden" id="deleteProductId">
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </button>
            <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                <i class="bi bi-trash"></i>
                حذف
            </button>
        </div>
    </div>
</div>

<!-- Preview/Details Modal -->
<div class="modal-overlay" id="previewModal">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h2>تفاصيل المنتج</h2>
        </div>
        <div class="modal-body">
            <div id="productPreviewContent">
                <div class="preview-section">
                    <div class="preview-image-container" id="previewImageContainer">
                        <img id="previewImage" src="" alt="" style="max-width: 100%; border-radius: 12px;">
                    </div>
                    
                    <div class="preview-grid">
                        <div class="preview-item">
                            <span class="preview-label">اسم المنتج:</span>
                            <span class="preview-value" id="previewName"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">الفئة:</span>
                            <span class="preview-value" id="previewCategory"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">سعر الشراء:</span>
                            <span class="preview-value" id="previewPurchasePrice"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">سعر البيع:</span>
                            <span class="preview-value" id="previewSalePrice"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">الكمية:</span>
                            <span class="preview-value" id="previewQuantity"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">الحد الأدنى:</span>
                            <span class="preview-value" id="previewMinStock"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">الباركود:</span>
                            <span class="preview-value" id="previewBarcode"></span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-label">الحالة:</span>
                            <span class="preview-value" id="previewStatus"></span>
                        </div>
                        <div class="preview-item" id="previewEngineContainer" style="display: none;">
                            <span class="preview-label">رقم المحرك:</span>
                            <span class="preview-value" id="previewEngine"></span>
                        </div>
                        <div class="preview-item" id="previewChassisContainer" style="display: none;">
                            <span class="preview-label">رقم الشاسيه:</span>
                            <span class="preview-value" id="previewChassis"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closePreviewModal()">
                <i class="bi bi-x-circle"></i>
                إغلاق
            </button>
        </div>
    </div>
</div>

<!-- Edit Modal - IMPROVED RESPONSIVE VERSION -->
<div class="modal-overlay" id="editModal">
    <div class="modal-content modal-edit-large">
        <div class="modal-header">
            <h2>
                <i class="bi bi-pencil-square"></i>
                تعديل المنتج
            </h2>
            <button type="button" class="btn-close-modal" onclick="closeEditModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form id="editProductForm">
            <div class="modal-body">
                <input type="hidden" id="editProductId">

                <!-- Image Section - Compact -->
                <div class="edit-image-section">
                    <div class="current-image-preview" id="editImagePreview">
                        <img id="editCurrentImage" src="" alt="" style="display: none;">
                        <div class="no-image-placeholder" id="editNoImage">
                            <i class="bi bi-image"></i>
                            <span>لا توجد صورة</span>
                        </div>
                    </div>
                    <div class="image-upload-control">
                        <label for="editImageFile" class="btn-upload-image">
                            <i class="bi bi-cloud-upload"></i>
                            تغيير الصورة
                        </label>
                        <input type="file" id="editImageFile" accept="image/*" style="display: none;" onchange="previewEditImage(event)">
                        <small class="form-hint">JPG, PNG أو GIF (حد أقصى 2MB)</small>
                    </div>
                </div>

                <!-- Form Fields Grid -->
                <div class="edit-form-grid">
                    <!-- Product Name -->
                    <div class="form-group form-full-width">
                        <label class="form-label">
                            <span class="required-star">*</span>
                            اسم المنتج
                        </label>
                        <input type="text" class="form-control" id="editName" required>
                    </div>

                    <!-- Category -->
                    <div class="form-group form-full-width">
                        <label class="form-label">
                            <span class="required-star">*</span>
                            الفئة
                        </label>
                        <select class="form-control" id="editCategoryId" required>
                            <option value="">اختر الفئة</option>
                        </select>
                    </div>

                    <!-- Prices Row -->
                    <div class="form-group">
                        <label class="form-label">
                            <span class="required-star">*</span>
                            سعر الشراء (ج.م)
                        </label>
                        <input type="number" class="form-control" id="editPurchasePrice" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <span class="required-star">*</span>
                            سعر البيع (ج.م)
                        </label>
                        <input type="number" class="form-control" id="editSalePrice" step="0.01" required>
                    </div>

                    <!-- Quantity Row -->
                    <div class="form-group">
                        <label class="form-label">
                            <span class="required-star">*</span>
                            الكمية
                        </label>
                        <input type="number" class="form-control" id="editQuantity" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">الحد الأدنى للمخزون</label>
                        <input type="number" class="form-control" id="editMinStock">
                    </div>

                    <!-- Barcode and Status -->
                    <div class="form-group">
                        <label class="form-label">الباركود</label>
                        <input type="text" class="form-control" id="editBarcode">
                    </div>
                    <div class="form-group">
                        <label class="form-label">الحالة</label>
                        <select class="form-control" id="editStatus">
                            <option value="0">جديد</option>
                            <option value="1">محجوز</option>
                            <option value="2">مُباع</option>
                        </select>
                    </div>

                    <!-- Motorcycle Toggle -->
                    <div class="form-group form-full-width">
                        <label class="form-checkbox">
                            <input type="checkbox" id="editIsMotorcycle" onchange="toggleMotorcycleFieldsEdit()">
                            <span>دراجة نارية (إضافة رقم المحرك والشاسيه)</span>
                        </label>
                    </div>

                    <!-- Motorcycle Fields -->
                    <div id="editMotorcycleFields" class="motorcycle-fields-container" style="display: none;">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-gear"></i>
                                رقم المحرك
                            </label>
                            <input type="text" class="form-control" id="editEngineNumber">
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-card-list"></i>
                                رقم الشاسيه
                            </label>
                            <input type="text" class="form-control" id="editChassisNumber">
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">
                    <i class="bi bi-x-circle"></i>
                    إلغاء
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i>
                    حفظ التعديلات
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <script src="~/js/Products/index.js"></script>
}