@model Domain.Entities.Product
@{
    var statusClass = Model.Status.ToString().ToLower();
    var statusText = Model.Status == Domain.Enums.ProductStatus.New ?"جديد": 
    Model.Status == Domain.Enums.ProductStatus.Reserved? 
    "محجوز" : "مباع";
}

<tr data-name="@Model.Name"
    data-barcode="@Model.Barcode"
    data-category="@Model.CategoryId"
>
    <td>
        <div class="product-image">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
            }
            else
            {
                <i class="bi bi-box-seam"></i>
            }
        </div>
    </td>
    <td>
        <div class="product-cell">
            <div class="product-info">
                <span class="product-name">@Model.Name</span>
                @if (!string.IsNullOrEmpty(Model.Barcode))
                {
                    <span class="product-sku">SKU: @Model.Barcode</span>
                }
            </div>
        </div>
    </td>
    <td>
        <span class="category-badge">@(Model.Category?.Name ?? "??? ????")</span>
    </td>
    <td class="price-cell">@Model.SalePrice.ToString("N0") ج.م</td>

    <td>
        <span class="status-badge @statusClass">@statusText</span>
    </td>
    <td>
        <div class="actions-cell">
            <a href="javascript:void(0)" onclick="openPreviewModal(@Model.Id)" class="btn-action btn-view" title="???">
                <i class="bi bi-eye"></i>
            </a>
            <a href="javascript:void(0)" onclick="openEditModal(@Model.Id)" class="btn-action btn-edit" title="?????">
                <i class="bi bi-pencil"></i>
            </a>
            <button onclick="openDeleteModal(@Model.Id, '@Model.Name')" class="btn-action btn-delete" title="???">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </td>
</tr>